<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1200.0"
            style="-fx-background-color: #f0f4f8;"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.oceanview.controller.ReservationsController">
    <children>

        <VBox prefWidth="230.0"
              AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
              style="-fx-background-color: #05142b;">
            <effect>
                <DropShadow color="#00000040" offsetX="4.0" radius="12.0" spread="0.05"/>
            </effect>
            <children>

                <VBox alignment="CENTER" prefHeight="120.0">
                    <VBox.margin><Insets top="10.0"/></VBox.margin>
                    <children>
                        <ImageView fitHeight="50.0" fitWidth="72.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@assets/images/logo.png"/></image>
                        </ImageView>
                        <Label text="OCEAN VIEW" textFill="#d4af37">
                            <font><Font name="Times New Roman Bold" size="15.0"/></font>
                            <VBox.margin><Insets top="6.0"/></VBox.margin>
                        </Label>
                        <Label text="Resort Management" textFill="#a0b3c6">
                            <font><Font size="10.0"/></font>
                        </Label>
                    </children>
                </VBox>

                <Rectangle height="1.0" width="180.0" fill="#d4af37" opacity="0.4">
                    <VBox.margin><Insets left="25.0" bottom="10.0"/></VBox.margin>
                </Rectangle>

                <Label text="MAIN MENU" textFill="#5a7a99">
                    <font><Font name="System Bold" size="10.0"/></font>
                    <VBox.margin><Insets left="25.0" bottom="6.0"/></VBox.margin>
                </Label>

                <Button fx:id="btnNavDashboard" mnemonicParsing="false" onAction="#showDashboard"
                        text=" &#x1F3E0;   Dashboard [F1]" prefWidth="210.0" prefHeight="40.0"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b3c6; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-background-radius: 8;">
                    <font><Font size="12.0"/></font>
                    <VBox.margin><Insets left="10.0" right="10.0" bottom="3.0"/></VBox.margin>
                </Button>

                <Button fx:id="btnNavReservations" mnemonicParsing="false"
                        text=" &#x1F4CB;   Reservations [F2]" prefWidth="210.0" prefHeight="40.0"
                        style="-fx-background-color: #d4af37; -fx-background-radius: 8; -fx-text-fill: #05142b; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                    <font><Font name="System Bold" size="12.0"/></font>
                    <VBox.margin><Insets left="10.0" right="10.0" bottom="3.0"/></VBox.margin>
                </Button>

                <Button fx:id="btnNavAddReservation" mnemonicParsing="false" onAction="#showAddReservation"
                        text=" &#x2795;   New Reservation [F3]" prefWidth="210.0" prefHeight="40.0"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b3c6; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-background-radius: 8;">
                    <font><Font size="12.0"/></font>
                    <VBox.margin><Insets left="10.0" right="10.0" bottom="3.0"/></VBox.margin>
                </Button>

                <Button fx:id="btnNavGuests" mnemonicParsing="false" onAction="#showGuests"
                        text=" &#x1F465;   Guests [F4]" prefWidth="210.0" prefHeight="40.0"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b3c6; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-background-radius: 8;">
                    <font><Font size="12.0"/></font>
                    <VBox.margin><Insets left="10.0" right="10.0" bottom="3.0"/></VBox.margin>
                </Button>

                <Button fx:id="btnNavBilling" mnemonicParsing="false" onAction="#showBilling"
                        text=" &#x1F4B3;   Billing [F5]" prefWidth="210.0" prefHeight="40.0"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b3c6; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-background-radius: 8;">
                    <font><Font size="12.0"/></font>
                    <VBox.margin><Insets left="10.0" right="10.0" bottom="3.0"/></VBox.margin>
                </Button>

                <Button fx:id="btnNavRooms" mnemonicParsing="false" onAction="#showRooms"
                        text=" &#x1F6CF;   Rooms [F6]" prefWidth="210.0" prefHeight="40.0"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b3c6; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-background-radius: 8;">
                    <font><Font size="12.0"/></font>
                    <VBox.margin><Insets left="10.0" right="10.0" bottom="3.0"/></VBox.margin>
                </Button>

                <VBox VBox.vgrow="ALWAYS"/>

                <Rectangle height="1.0" width="180.0" fill="#1e3a5f" opacity="0.8">
                    <VBox.margin><Insets left="25.0" bottom="8.0"/></VBox.margin>
                </Rectangle>

                <Button fx:id="btnNavHelp" mnemonicParsing="false" onAction="#showHelp"
                        text=" &#x2753;   Help [F11]" prefWidth="210.0" prefHeight="40.0"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b3c6; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-background-radius: 8;">
                    <font><Font size="12.0"/></font>
                    <VBox.margin><Insets left="10.0" right="10.0" bottom="3.0"/></VBox.margin>
                </Button>

                <Button fx:id="btnLogout" mnemonicParsing="false" onAction="#handleLogout"
                        text=" &#x1F6AA;   Logout [F12]" prefWidth="210.0" prefHeight="40.0"
                        style="-fx-background-color: transparent; -fx-text-fill: #e74c3c; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-background-radius: 8;">
                    <font><Font size="12.0"/></font>
                    <VBox.margin><Insets left="10.0" right="10.0" bottom="15.0"/></VBox.margin>
                </Button>

            </children>
        </VBox>

        <VBox AnchorPane.leftAnchor="230.0" AnchorPane.rightAnchor="0"
              AnchorPane.topAnchor="0"      AnchorPane.bottomAnchor="0">
            <children>

                <HBox prefHeight="60.0" alignment="CENTER_LEFT"
                      style="-fx-background-color: #ffffff; -fx-padding: 0 20 0 20;">
                    <effect><DropShadow color="#00000015" offsetY="2.0" radius="6.0"/></effect>
                    <children>
                        <VBox>
                            <children>
                                <Label text="Reservations" textFill="#05142b">
                                    <font><Font name="System Bold" size="18.0"/></font>
                                </Label>
                                <Label text="Manage all guest reservations." textFill="#888888">
                                    <font><Font size="11.0"/></font>
                                </Label>
                            </children>
                        </VBox>
                        <HBox HBox.hgrow="ALWAYS"/>
                        <HBox alignment="CENTER_LEFT" spacing="6.0"
                              style="-fx-background-color: #f0f4f8; -fx-background-radius: 18; -fx-padding: 5 12 5 12;">
                            <children>
                                <Label text="&#x1F50D;" style="-fx-text-fill: #888888;"/>
                                <TextField fx:id="txtSearch" promptText="Search by name or reservation no..."
                                           prefWidth="230.0"
                                           style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: #333333;">
                                    <font><Font size="12.0"/></font>
                                </TextField>
                            </children>
                        </HBox>
                        <Button mnemonicParsing="false" onAction="#showAddReservation"
                                text="+ New Reservation" prefHeight="36.0" prefWidth="155.0"
                                style="-fx-background-color: #d4af37; -fx-background-radius: 8; -fx-text-fill: #05142b; -fx-cursor: hand;">
                            <font><Font name="System Bold" size="12.0"/></font>
                            <HBox.margin><Insets left="12.0"/></HBox.margin>
                        </Button>
                        <HBox alignment="CENTER" spacing="8.0"
                              style="-fx-background-color: #05142b; -fx-background-radius: 18; -fx-padding: 5 14 5 14;">
                            <HBox.margin><Insets left="12.0"/></HBox.margin>
                            <children>
                                <Label text="&#x1F464;" style="-fx-text-fill: #d4af37;"/>
                                <Label fx:id="lblLoggedInUser" text="Admin" textFill="#ffffff">
                                    <font><Font name="System Bold" size="12.0"/></font>
                                </Label>
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" hbarPolicy="NEVER"
                            style="-fx-background: #f0f4f8; -fx-background-color: #f0f4f8;
                                   -fx-border-color: transparent; -fx-focus-color: transparent;">
                    <content>
                        <VBox spacing="14.0" style="-fx-padding: 18 20 18 20;">
                            <children>

                                <HBox spacing="14.0">
                                    <children>

                                        <HBox prefHeight="64.0" HBox.hgrow="ALWAYS" spacing="0"
                                              style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-padding: 0;">
                                            <effect><DropShadow color="#00000010" offsetY="2.0" radius="8.0"/></effect>
                                            <children>
                                                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                                                      style="-fx-padding: 12 0 12 0;">
                                                    <children>
                                                        <Label fx:id="lblStatTotal" text="128" textFill="#05142b">
                                                            <font><Font name="System Bold" size="22.0"/></font>
                                                        </Label>
                                                        <Label text="Total" textFill="#888888">
                                                            <font><Font size="10.0"/></font>
                                                        </Label>
                                                    </children>
                                                </VBox>

                                                <Rectangle width="1.0" height="40.0" fill="#eeeeee"/>

                                                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                                                      style="-fx-padding: 12 0 12 0;">
                                                    <children>
                                                        <Label fx:id="lblStatCheckedIn" text="34" textFill="#27ae60">
                                                            <font><Font name="System Bold" size="22.0"/></font>
                                                        </Label>
                                                        <Label text="Checked In" textFill="#888888">
                                                            <font><Font size="10.0"/></font>
                                                        </Label>
                                                    </children>
                                                </VBox>

                                                <Rectangle width="1.0" height="40.0" fill="#eeeeee"/>

                                                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                                                      style="-fx-padding: 12 0 12 0;">
                                                    <children>
                                                        <Label fx:id="lblStatReserved" text="22" textFill="#d4af37">
                                                            <font><Font name="System Bold" size="22.0"/></font>
                                                        </Label>
                                                        <Label text="Reserved" textFill="#888888">
                                                            <font><Font size="10.0"/></font>
                                                        </Label>
                                                    </children>
                                                </VBox>

                                                <Rectangle width="1.0" height="40.0" fill="#eeeeee"/>

                                                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                                                      style="-fx-padding: 12 0 12 0;">
                                                    <children>
                                                        <Label fx:id="lblStatCheckedOut" text="68" textFill="#3498db">
                                                            <font><Font name="System Bold" size="22.0"/></font>
                                                        </Label>
                                                        <Label text="Checked Out" textFill="#888888">
                                                            <font><Font size="10.0"/></font>
                                                        </Label>
                                                    </children>
                                                </VBox>

                                                <Rectangle width="1.0" height="40.0" fill="#eeeeee"/>

                                                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                                                      style="-fx-padding: 12 0 12 0;">
                                                    <children>
                                                        <Label fx:id="lblStatCancelled" text="4" textFill="#e74c3c">
                                                            <font><Font name="System Bold" size="22.0"/></font>
                                                        </Label>
                                                        <Label text="Cancelled" textFill="#888888">
                                                            <font><Font size="10.0"/></font>
                                                        </Label>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                    </children>
                                </HBox>

                                <HBox spacing="10.0" alignment="CENTER_LEFT"
                                      style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-padding: 12 16 12 16;">
                                    <effect><DropShadow color="#00000010" offsetY="2.0" radius="8.0"/></effect>
                                    <children>
                                        <Label text="Filter:" textFill="#555555">
                                            <font><Font name="System Bold" size="12.0"/></font>
                                        </Label>

                                        <ComboBox fx:id="cmbStatusFilter" promptText="All Statuses"
                                                  prefWidth="145.0" prefHeight="34.0"
                                                  style="-fx-background-color: #f0f4f8; -fx-background-radius: 7; -fx-border-color: transparent; -fx-text-fill: #333333;">
                                        </ComboBox>

                                        <ComboBox fx:id="cmbRoomTypeFilter" promptText="All Room Types"
                                                  prefWidth="155.0" prefHeight="34.0"
                                                  style="-fx-background-color: #f0f4f8; -fx-background-radius: 7; -fx-border-color: transparent;">
                                        </ComboBox>

                                        <HBox alignment="CENTER_LEFT" spacing="6.0"
                                              style="-fx-background-color: #f0f4f8; -fx-background-radius: 7; -fx-padding: 5 10 5 10;">
                                            <children>
                                                <Label text="From" textFill="#888888"><font><Font size="11.0"/></font></Label>
                                                <TextField fx:id="txtDateFrom" promptText="YYYY-MM-DD"
                                                           prefWidth="110.0" prefHeight="24.0"
                                                           style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: #333333;">
                                                    <font><Font size="12.0"/></font>
                                                </TextField>
                                            </children>
                                        </HBox>

                                        <HBox alignment="CENTER_LEFT" spacing="6.0"
                                              style="-fx-background-color: #f0f4f8; -fx-background-radius: 7; -fx-padding: 5 10 5 10;">
                                            <children>
                                                <Label text="To" textFill="#888888"><font><Font size="11.0"/></font></Label>
                                                <TextField fx:id="txtDateTo" promptText="YYYY-MM-DD"
                                                           prefWidth="110.0" prefHeight="24.0"
                                                           style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: #333333;">
                                                    <font><Font size="12.0"/></font>
                                                </TextField>
                                            </children>
                                        </HBox>

                                        <Button mnemonicParsing="false" onAction="#applyFilters"
                                                text="Apply" prefHeight="34.0" prefWidth="80.0"
                                                style="-fx-background-color: #05142b; -fx-background-radius: 7; -fx-text-fill: #ffffff; -fx-cursor: hand;">
                                            <font><Font name="System Bold" size="12.0"/></font>
                                        </Button>

                                        <Button mnemonicParsing="false" onAction="#clearFilters"
                                                text="Clear" prefHeight="34.0" prefWidth="70.0"
                                                style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-radius: 7; -fx-background-radius: 7; -fx-text-fill: #666666; -fx-cursor: hand;">
                                            <font><Font size="12.0"/></font>
                                        </Button>

                                        <HBox HBox.hgrow="ALWAYS"/>

                                        <Button mnemonicParsing="false" onAction="#exportToCSV"
                                                text="&#x2B07; Export CSV" prefHeight="34.0" prefWidth="120.0"
                                                style="-fx-background-color: transparent; -fx-border-color: #d4af37; -fx-border-radius: 7; -fx-background-radius: 7; -fx-text-fill: #d4af37; -fx-cursor: hand;">
                                            <font><Font name="System Bold" size="12.0"/></font>
                                        </Button>
                                    </children>
                                </HBox>

                                <VBox spacing="0"
                                      style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-padding: 0;">
                                    <effect><DropShadow color="#00000010" offsetY="2.0" radius="8.0"/></effect>
                                    <children>

                                        <HBox prefHeight="46.0" alignment="CENTER_LEFT"
                                              style="-fx-background-color: #ffffff; -fx-background-radius: 12 12 0 0; -fx-padding: 0 16 0 16;
                                                     -fx-border-color: transparent transparent #f0f4f8 transparent; -fx-border-width: 0 0 1 0;">
                                            <children>
                                                <Label text="All Reservations" textFill="#05142b">
                                                    <font><Font name="System Bold" size="13.0"/></font>
                                                </Label>
                                                <HBox HBox.hgrow="ALWAYS"/>
                                                <Label fx:id="lblResultCount" text="Showing 128 results" textFill="#888888">
                                                    <font><Font size="11.0"/></font>
                                                </Label>
                                            </children>
                                        </HBox>

                                        <TableView fx:id="tblReservations" prefHeight="400.0"
                                                   style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-table-cell-border-color: #f5f5f5;">
                                            <columns>
                                                <TableColumn fx:id="colResNo"      text="Res. No"      prefWidth="90.0"  style="-fx-font-weight: bold;"/>
                                                <TableColumn fx:id="colGuestName"  text="Guest Name"   prefWidth="160.0"/>
                                                <TableColumn fx:id="colContact"    text="Contact"      prefWidth="120.0"/>
                                                <TableColumn fx:id="colRoomType"   text="Room Type"    prefWidth="120.0"/>
                                                <TableColumn fx:id="colCheckIn"    text="Check-In"     prefWidth="105.0"/>
                                                <TableColumn fx:id="colCheckOut"   text="Check-Out"    prefWidth="105.0"/>
                                                <TableColumn fx:id="colNights"     text="Nights"       prefWidth="65.0"/>
                                                <TableColumn fx:id="colAmount"     text="Amount (LKR)" prefWidth="110.0"/>
                                                <TableColumn fx:id="colStatus"     text="Status"       prefWidth="100.0"/>
                                                <TableColumn fx:id="colActions"    text="Actions"      prefWidth="120.0"/>
                                            </columns>
                                        </TableView>

                                    </children>
                                </VBox>

                                <HBox alignment="CENTER" spacing="8.0"
                                      style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-padding: 12 16 12 16;">
                                    <effect><DropShadow color="#00000010" offsetY="2.0" radius="8.0"/></effect>
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#prevPage"
                                                text="&#x25C0; Prev" prefHeight="32.0" prefWidth="80.0"
                                                style="-fx-background-color: transparent; -fx-border-color: #dddddd; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: #555555; -fx-cursor: hand;">
                                            <font><Font size="11.0"/></font>
                                        </Button>

                                        <Button fx:id="btnPage1" mnemonicParsing="false" onAction="#showPage"
                                                text="1" prefHeight="32.0" prefWidth="32.0"
                                                style="-fx-background-color: #d4af37; -fx-background-radius: 6; -fx-text-fill: #05142b; -fx-cursor: hand;">
                                            <font><Font name="System Bold" size="11.0"/></font>
                                        </Button>
                                        <Button fx:id="btnPage2" mnemonicParsing="false" onAction="#showPage"
                                                text="2" prefHeight="32.0" prefWidth="32.0"
                                                style="-fx-background-color: transparent; -fx-border-color: #dddddd; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: #555555; -fx-cursor: hand;">
                                            <font><Font size="11.0"/></font>
                                        </Button>
                                        <Button fx:id="btnPage3" mnemonicParsing="false" onAction="#showPage"
                                                text="3" prefHeight="32.0" prefWidth="32.0"
                                                style="-fx-background-color: transparent; -fx-border-color: #dddddd; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: #555555; -fx-cursor: hand;">
                                            <font><Font size="11.0"/></font>
                                        </Button>
                                        <Label text="..." textFill="#aaaaaa"><font><Font size="12.0"/></font></Label>
                                        <Button fx:id="btnPageLast" mnemonicParsing="false" onAction="#showPage"
                                                text="13" prefHeight="32.0" prefWidth="32.0"
                                                style="-fx-background-color: transparent; -fx-border-color: #dddddd; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: #555555; -fx-cursor: hand;">
                                            <font><Font size="11.0"/></font>
                                        </Button>

                                        <Button mnemonicParsing="false" onAction="#nextPage"
                                                text="Next &#x25B6;" prefHeight="32.0" prefWidth="80.0"
                                                style="-fx-background-color: transparent; -fx-border-color: #dddddd; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: #555555; -fx-cursor: hand;">
                                            <font><Font size="11.0"/></font>
                                        </Button>

                                        <HBox HBox.hgrow="ALWAYS"/>
                                        <Label text="Rows per page:" textFill="#888888"><font><Font size="11.0"/></font></Label>
                                        <ComboBox fx:id="cmbRowsPerPage" prefWidth="70.0" prefHeight="32.0"
                                                  style="-fx-background-color: #f0f4f8; -fx-background-radius: 6; -fx-border-color: transparent;">
                                        </ComboBox>

                                    </children>
                                </HBox>

                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

            </children>
        </VBox>

    </children>
</AnchorPane>